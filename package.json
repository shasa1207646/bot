{
  "name": "discord-bot-with-site",
  "version": "1.0.0",
  "description": "Discord bot with website and application system",
  "main": "dist/index.js",
  "scripts": {
    "build": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --external:discord.js --external:express",
    "start": "node dist/index.js",
    "dev": "esbuild src/index.ts --bundle --platform=node --outfile=dist/index.js --external:discord.js --external:express --watch"
  },
  "dependencies": {
    "discord.js": "^14.14.1",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.10.0",
    "esbuild": "^0.19.8",
    "typescript": "^5.3.2"
  }
}
